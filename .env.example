# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token

# Domain Configuration
DOMAIN=temp.example.com
API_URL=https://your-pmail-api.your-subdomain.workers.dev
APP_URL=https://your-pmail-web.pages.dev

# Database ID
D1_DATABASE_ID=your_d1_database_id

# Cloudflare Pages project name (rendered by scripts/bootstrap.mjs)
PAGES_PROJECT_NAME=your_pages_project_name

# Secrets (set via wrangler secret)
# JWT_SECRET=your_jwt_secret_min_32_chars
# SENDGRID_API_KEY=your_sendgrid_api_key
