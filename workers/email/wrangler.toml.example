# =============================================================================
# envsubst template for wrangler.toml (PMail Email Worker)
# =============================================================================
# DO NOT edit this file to add real IDs. CI (GitHub Actions) renders the real
# wrangler.toml at deploy time via:
#
#   envsubst < workers/email/wrangler.toml.example > workers/email/wrangler.toml
#
# IMPORTANT: D1 database_id / database_name, R2 bucket and shared KV ids MUST
# resolve to the same values used by workers/api/wrangler.toml.example so both
# workers operate on the same backing resources.
# Local development: copy this file to wrangler.toml manually and fill values.
# =============================================================================

name = "pmail-receiver"
main = "src/index.ts"
compatibility_date = "2024-01-01"

# Compatibility flags
compatibility_flags = [
  "nodejs_compat"
]

# Workers configuration
workers_dev = false

# D1 Database binding (MUST match API worker)
[[d1_databases]]
binding = "DB"
database_name = "${D1_DATABASE_NAME}"
database_id = "${D1_DATABASE_ID}"

# R2 Storage bucket binding (for attachments under attachments/ prefix)
[[r2_buckets]]
binding = "R2"
bucket_name = "${R2_BUCKET}"

# KV - shared cache (MUST match API worker's CACHE id)
# Used here for active_domains lookup and email_valid:* recipient cache.
[[kv_namespaces]]
binding = "CACHE"
id = "${KV_CACHE_ID}"

# Environment variables
# NOTE: [vars] MUST be the LAST top-level section in this file. Per TOML rules,
# any bare key (e.g. compatibility_flags, workers_dev) placed AFTER a table
# header like [vars] is parsed as a key INSIDE that table, which means Wrangler
# will silently ignore it as an unknown var.
[vars]
DOMAIN = "${DOMAIN}"
MAX_EMAIL_SIZE = "26214400"
MAX_ATTACHMENTS = "10"
MAX_ATTACHMENT_SIZE = "10485760"

# Email routing configuration
# Configure this in Cloudflare Dashboard under Email Routing
# Route pattern: *@${DOMAIN} -> this worker
