# =============================================================================
# envsubst template for wrangler.toml (PMail API Worker)
# =============================================================================
# DO NOT edit this file to add real IDs. CI (GitHub Actions) renders the real
# wrangler.toml at deploy time via:
#
#   envsubst < workers/api/wrangler.toml.example > workers/api/wrangler.toml
#
# Every `${VAR}` placeholder below must be exported in the CI environment
# before envsubst runs (typically from GitHub Actions secrets/vars).
# Local development: copy this file to wrangler.toml manually and fill values.
# =============================================================================

name = "pmail-api"
main = "src/index.ts"
compatibility_date = "2024-01-01"

# Compatibility flags
compatibility_flags = [
  "nodejs_compat",
  "streams_enable_constructors"
]

# Usage model
usage_model = "standard"

# Workers configuration
workers_dev = true

# Triggers - Cron jobs for scheduled tasks
[triggers]
crons = [
  "0 * * * *",        # Every hour - Clean expired data + tier expiration check
  "0 2 * * *"         # Every day at 2:00 AM UTC - DB backup
]

# D1 Database binding
[[d1_databases]]
binding = "DB"
database_name = "${D1_DATABASE_NAME}"
database_id = "${D1_DATABASE_ID}"
migrations_dir = "migrations"

# R2 Storage bucket binding (attachments under attachments/ prefix, backups under backups/ prefix)
[[r2_buckets]]
binding = "R2"
bucket_name = "${R2_BUCKET}"

# KV Namespaces
# CACHE - shared cache for all transient lookups, namespaced by key prefix:
#   reset:*        password reset tokens
#   email_valid:*  validated recipient address cache (only positive hits)
#   settings:*     app-level cached config (active_domains, etc.)
[[kv_namespaces]]
binding = "CACHE"
id = "${KV_CACHE_ID}"

# Placement hints for better performance
[placement]
mode = "smart"

# Observability
[observability]
enabled = true
head_sampling_rate = 0.1

# Environment variables
# NOTE: [vars] MUST be the LAST top-level section in this file. Per TOML rules,
# any bare key (e.g. compatibility_flags, usage_model, workers_dev) placed AFTER
# a table header like [vars] is parsed as a key INSIDE that table, which means
# Wrangler will silently ignore it as an unknown var.
[vars]
DOMAIN = "${DOMAIN}"
ALLOWED_ORIGINS = "${ALLOWED_ORIGINS}"
ENABLE_AUDIT_LOG = "true"
DEFAULT_MAILBOX_TTL = "3600"
MAX_EMAIL_SIZE = "26214400"
MAX_ATTACHMENTS = "10"
MAX_ATTACHMENT_SIZE = "10485760"

# Guest mode settings
GUEST_MAILBOX_TTL = "7200"  # 2 hours (in seconds)
GUEST_CLEANUP_RETENTION = "86400"  # Keep expired guest mailboxes for 24 hours before deletion

# Cloudflare API (for email forwarding destination management)
CLOUDFLARE_ACCOUNT_ID = "${CLOUDFLARE_ACCOUNT_ID}"

# Backup settings
BACKUP_ENABLED = "true"
BACKUP_RETENTION_DAYS = "30"  # Retain backups for 30 days

# Secrets (use: wrangler secret put <KEY_NAME>)
# JWT_SECRET - JWT signing key (any random string, at least 32 chars)
#   Generate with: openssl rand -base64 32
# CLOUDFLARE_API_TOKEN - API token with "Email Routing Addresses: Edit" scope
#   Required only if email forwarding feature is enabled
#   Create at: https://dash.cloudflare.com/profile/api-tokens
#   Deploy with: wrangler secret put CLOUDFLARE_API_TOKEN
