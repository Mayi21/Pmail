# Copy this file to web/.env and fill in your own values.

# API base URL (your deployed pmail-api worker, or local dev URL)
VITE_API_BASE_URL=https://api.your-domain.com

# Cloudflare Turnstile site key (public-facing, get one at https://dash.cloudflare.com/?to=/:account/turnstile)
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
